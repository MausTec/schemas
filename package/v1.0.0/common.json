{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://schemas.maus-tec.com/package/v1.0.0/common.json",
    "title": "EOM Package Common Definitions",
    "description": "Shared definitions for all EOM distributable artifact manifests — JSON plugins, WASM apps, audio packs, etc. Not intended to be used as a root schema; consumer schemas compose these via $ref.",

    "$defs": {
        "artifactType": {
            "type": "string",
            "description": "Artifact type discriminator. Determines how the device and Hub handle the package.",
            "enum": ["feature", "ble_driver", "app"]
        },

        "permission": {
            "description": "Permission token in 'resource:action' format. Controls access to host API functions and events.",
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*:[a-z][a-z0-9_]*$",
            "examples": ["ble:write", "syscfg:read", "syscfg:write", "arousal:read"]
        },

        "permissionList": {
            "type": "array",
            "description": "Permissions required by this artifact. If omitted, no special permissions are requested.",
            "items": {
                "$ref": "#/$defs/permission"
            },
            "uniqueItems": true
        },

        "configField": {
            "type": "object",
            "description": "A single user-adjustable configuration field.",
            "required": ["type", "default"],
            "properties": {
                "type": {
                    "type": "string",
                    "enum": ["int", "bool", "string"],
                    "description": "Value type — enforced at runtime."
                },
                "default": {
                    "description": "Default value used when no user config is saved. Must match 'type'."
                },
                "label": {
                    "type": "string",
                    "description": "Display name shown in the device config menu. Falls back to the field key if omitted."
                },
                "description": {
                    "type": "string",
                    "description": "Help text (reserved for future UI use)."
                },
                "min": {
                    "type": "integer",
                    "description": "Minimum value (int) or minimum length (string)."
                },
                "max": {
                    "type": "integer",
                    "description": "Maximum value (int) or maximum length (string)."
                }
            },
            "additionalProperties": false
        },

        "configSchema": {
            "type": "object",
            "description": "Map of field names to config field definitions. Persisted to /plugincfg/<name>.json on SD.",
            "additionalProperties": {
                "$ref": "#/$defs/configField"
            }
        },

        "hubMetadata": {
            "type": "object",
            "description": "Hub distribution metadata. These fields are consumed by the Maus-Tec Hub for indexing, display, and verification. The device ignores them at runtime.",
            "required": ["name", "version", "sdkVersion", "displayName", "description", "author", "license", "repository"],
            "properties": {
                "name": {
                    "type": "string",
                    "description": "Unique package identifier (lowercase, hyphens). Used as the Hub slug.",
                    "pattern": "^[a-z][a-z0-9-]*$",
                    "examples": ["lovense-driver", "clench-detector"]
                },
                "version": {
                    "type": "string",
                    "description": "Package version in semver format.",
                    "pattern": "^\\d+\\.\\d+\\.\\d+",
                    "examples": ["0.1.0", "1.0.0"]
                },
                "sdkVersion": {
                    "type": "string",
                    "description": "Minimum eom-sdk version required by this package.",
                    "pattern": "^\\d+\\.\\d+\\.\\d+",
                    "examples": ["1.0.0"]
                },
                "displayName": {
                    "type": "string",
                    "description": "Human-readable name for menus and Hub listing."
                },
                "description": {
                    "type": "string",
                    "description": "Short description for Hub listing."
                },
                "author": {
                    "type": "string",
                    "description": "Author name or organization."
                },
                "license": {
                    "type": "string",
                    "description": "SPDX license identifier.",
                    "examples": ["MIT", "GPL-3.0-only", "Apache-2.0"]
                },
                "repository": {
                    "type": "string",
                    "format": "uri",
                    "description": "Public source repository URL — required for Hub distribution."
                },
                "signature": {
                    "type": "string",
                    "description": "Base64-encoded signature produced by 'eom-sdk sign'. Verified by Hub on upload; device-side enforcement planned."
                }
            },
            "additionalProperties": true
        }
    }
}
